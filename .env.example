# Trove — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Local AI (Ollama) ────────────────────────────────────────────────
# No API key needed — just install Ollama (https://ollama.com)
OLLAMA_RAG_MODEL=mistral:latest          # RAG search answers
OLLAMA_EMBED_MODEL=nomic-embed-text      # Semantic embeddings
OLLAMA_MODEL=qwen3:8b                    # General chat

# ── Cloud AI (optional) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=                        # https://console.anthropic.com/settings/keys

# ── Connectors — add only the ones you use ───────────────────────────
GITHUB_TOKEN=                             # https://github.com/settings/tokens
NOTION_TOKEN=                             # https://www.notion.so/my-integrations
FIGMA_TOKEN=                              # https://www.figma.com/developers/api#access-tokens
SLACK_TOKEN=                              # https://api.slack.com/apps
LINEAR_TOKEN=                             # https://linear.app/settings/api
DISCORD_TOKEN=                            # https://discord.com/developers/applications
AIRTABLE_TOKEN=                           # https://airtable.com/create/tokens
DROPBOX_TOKEN=                            # https://www.dropbox.com/developers/apps
GOOGLE_TOKEN=                             # https://console.cloud.google.com/apis/credentials
CONFLUENCE_TOKEN=                         # https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_EMAIL=
RAINDROP_TOKEN=                           # https://app.raindrop.io/settings/integrations

# ── Security (optional) ─────────────────────────────────────────────
# TROVE_ENCRYPTION_KEY=                   # AES-256-GCM encryption at rest
# TROVE_API_TOKEN=                        # Fixed dashboard token (auto-generated if omitted)
